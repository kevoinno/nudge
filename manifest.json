{
  "manifest_version": 3,
  "name": "Nudge",
  "version": "1.0",
  "description": "Reduce doomscrolling and connect with the people that matter",
  "icons": { "48": "icon.png" },
  "browser_specific_settings": {
    "gecko": {
      "id": "nudge@personal",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "permissions": ["tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.reddit.com/*",
        "*://*.twitch.tv/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
