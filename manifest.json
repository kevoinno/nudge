{
  "manifest_version": 3,
  "name": "Nudge",
  "version": "1.0",

  "description": "Placeholder for firefox demo",

  "icons": {
    "48": "icon.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "borderify@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.mozilla.org/*"],
      "js": ["borderify.js"]
    }
  ]
}
